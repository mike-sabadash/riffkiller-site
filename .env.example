# Riff Killer - Environment variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Canonical site URL (for OAuth redirect_uri). Set on production so Google/Yandex callbacks work.
# Example: SITE_URL=https://riffkiller.fun
# SITE_URL=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Cryptomus (https://cryptomus.com)
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# Patreon (optional - for token exchange proxy)
# PATREON_PROXY_URL=https://your-project.vercel.app/api/exchange

# Optional: internal API key for api/subscription/update.php (server-to-server)
# SUBSCRIPTION_UPDATE_SECRET=

# Email campaigns (Resend)
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=Riff Killer <hello@your-domain.com>
# Optional webhook secret (match in Resend webhook settings)
# RESEND_WEBHOOK_SECRET=your_webhook_secret
